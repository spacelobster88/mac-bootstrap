# === Performance Tuning Environment Variables ===
# Snapshot: v1.1.0 (2026-03-18)

# --- Gateway (mini-claude-bot) ---
GATEWAY_MAX_CLAUDE_PROCESSES=16       # Max concurrent Claude CLI processes (from plist)
GATEWAY_CLAUDE_TIMEOUT=86400          # 24h timeout for long sessions (from plist)
GATEWAY_QUEUE_WAIT_TIMEOUT=300        # 5 min queue wait (from plist, overrides code default 120)
GATEWAY_SESSION_DIR=/Users/spacelobster/claude-gateway-sessions

# --- Centurion Scheduler ---
CENTURION_PORT=8100                   # API port
CENTURION_RAM_HEADROOM_GB=2           # Reserved RAM headroom
CENTURION_MAX_AGENTS_HARD_LIMIT=0     # 0 = no hard limit (use dynamic)
CENTURION_PROBE_CACHE_TTL=2           # System probe cache in seconds

# --- Harness Loop ---
HARNESS_CHAIN_DELAY=5                 # Seconds between batch completions
MAX_HARNESS_CHAIN_DEPTH=100           # Max auto-chain iterations
BUSY_STUCK_TIMEOUT=660                # 11 min — force-clear stuck tasks
CLAUDE_TIMEOUT=600                    # 10 min for normal foreground chat
QUEUE_WAIT_TIMEOUT=120                # 2 min queue wait before rejecting
MAX_OOM_RETRIES=2                     # Claude CLI OOM retry count
OOM_RETRY_BACKOFF=15                  # Seconds between OOM retries

# --- Ollama ---
OLLAMA_FLASH_ATTENTION=1              # Enable flash attention
OLLAMA_KV_CACHE_TYPE=q8_0             # Quantized KV cache
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text   # 768-dim vectors

# --- Memory Pressure Thresholds (Centurion) ---
# Compressor ratio > 0.30 → WARN
# Compressor ratio > 0.50 → CRITICAL
# Dynamic headroom multipliers: NORMAL=1.0x, WARN=1.75x, CRITICAL=2.5x

# --- Docker ---
DOCKER_MEMORY_LIMIT=2g                # Docker Desktop memory limit
DOCKER_CPU_LIMIT=2                    # Docker Desktop CPU limit
